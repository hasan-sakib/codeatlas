# Copy to .env and fill in real values for local development.
# Never commit a populated .env file.
#
# The DATABASE__URL/QDRANT__URL/REDIS__URL/OLLAMA__BASE_URL values below
# use `localhost`, which is correct when running backend-api/worker
# directly on the host (`uv run uvicorn ...`) against Dockerized infra
# (Postgres/Redis/Qdrant/Ollama started via docker-compose.dev.yml's
# published ports) — the workflow used to develop/verify every backend
# module so far. When backend-api/worker run *as containers* on
# infra/docker's Compose network instead, `infra/docker/docker-compose.yml`
# overrides these four keys to the Docker service DNS names
# (`postgres`/`qdrant`/`redis`/`ollama`) directly — `environment:` always
# wins over `env_file:`, so no edit is needed here for that case.

ENVIRONMENT=local
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# --- Database (Module 2/4) ---
DATABASE__URL=postgresql+asyncpg://codeatlas:codeatlas@localhost:5432/codeatlas
DATABASE__POOL_SIZE=10
DATABASE__MAX_OVERFLOW=5
DATABASE__ECHO=false

# --- Qdrant (Module 2/10) ---
QDRANT__URL=http://localhost:6333
QDRANT__API_KEY=
QDRANT__COLLECTION_PREFIX=code_chunks
QDRANT__TIMEOUT_SECONDS=30.0

# --- Redis (Module 2/9) ---
REDIS__URL=redis://localhost:6379/0
REDIS__CACHE_TTL_SECONDS=3600

# --- Ollama (Module 2/14) ---
OLLAMA__BASE_URL=http://localhost:11434
OLLAMA__MODEL_NAME=qwen3:4b
OLLAMA__REQUEST_TIMEOUT_SECONDS=120.0
OLLAMA__NUM_CTX=16384
OLLAMA__MAX_RETRIES=3
OLLAMA__RETRY_BACKOFF_SECONDS=1.0

# --- Security (Module 2/5) ---
SECURITY__JWT_SECRET_KEY=changeme-generate-a-real-secret-for-any-non-local-env
SECURITY__JWT_ALGORITHM=HS256
SECURITY__ACCESS_TOKEN_EXPIRE_MINUTES=15
SECURITY__REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Git cloning (Module 2/6) ---
GIT__CLONE_TIMEOUT_SECONDS=120.0
GIT__MAX_REPO_SIZE_MB=500

# --- Chunking (Module 2/8) ---
CHUNKING__MAX_CHUNK_TOKENS=512
CHUNKING__MIN_CHUNK_TOKENS=64
CHUNKING__MERGE_TARGET_TOKENS=256

# --- Embedding (Module 2/9) ---
EMBEDDING__MODEL_NAME_OR_PATH=BAAI/bge-m3
EMBEDDING__MODEL_ID=bge-m3:v1
EMBEDDING__BATCH_SIZE=32
EMBEDDING__USE_FP16=true
EMBEDDING__CACHE_TTL_SECONDS=2592000

# --- Reranker (Module 2/12) ---
RERANKER__MODEL_NAME=BAAI/bge-reranker-base
RERANKER__MAX_LENGTH=512
RERANKER__BATCH_SIZE=16
RERANKER__DEVICE=cpu
RERANKER__FAIL_OPEN=true

# --- Conversation (Module 2/15) ---
CONVERSATION__SUMMARY_THRESHOLD=10
CONVERSATION__CONTEXT_WINDOW_TURNS=20

# --- Agent (Module 2/13) ---
AGENT__MAX_RETRIEVAL_ATTEMPTS=2
AGENT__MAX_TOOL_CALLS=3
AGENT__RETRY_K_MULTIPLIER=2
AGENT__CLASSIFY_INTENT_MAX_TOKENS=1024
AGENT__REWRITE_QUERY_MAX_TOKENS=1024
AGENT__GENERATE_ANSWER_MAX_TOKENS=4096
AGENT__CONTEXT_CHUNK_COUNT=8

# --- Rate limiting (Module 2/17) ---
RATE_LIMIT__AUTH_PER_IP_PER_MINUTE=5
RATE_LIMIT__CHAT_PER_USER_PER_MINUTE=30
RATE_LIMIT__INDEXING_TRIGGER_PER_USER_PER_MINUTE=3

# --- Frontend session cookie (Module 18/19) ---
# Signs the frontend's own httpOnly session cookie; unrelated to
# SECURITY__JWT_SECRET_KEY above. Generate with: openssl rand -base64 32
# Not read from this file when running the frontend outside Docker
# (it uses frontend/.env.local instead) — only consumed here by the
# `frontend` service in infra/docker/docker-compose.yml.
SESSION_SECRET=changeme-generate-a-real-secret-for-any-non-local-env
