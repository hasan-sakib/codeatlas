# Server-only: the FastAPI backend's base URL (no trailing slash, no
# /api/v1 suffix — that's appended by lib/backend.ts and the BFF proxy
# route). Never exposed to the browser; only Server Components, Server
# Actions, and the app/api/backend/[...path] route ever read this.
BACKEND_URL=http://localhost:8000

# Server-only: signs/verifies the httpOnly session cookie that wraps the
# backend's access+refresh tokens. Unrelated to the backend's own
# SECURITY__JWT_SECRET_KEY. Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-32-byte-value
